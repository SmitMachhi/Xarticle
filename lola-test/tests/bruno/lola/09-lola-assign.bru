meta {
  name: 09 Lola - Assign Kitchen Tasks (SSE)
  type: http
  seq: 13
}

post {
  url: {{BASE_URL}}/lola/message
  body: json
  auth: bearer
}

auth:bearer {
  token: {{JWT_1}}
}

headers {
  Accept: text/event-stream
}

body:json {
  {
    "content": "assign all kitchen tasks to me"
  }
}

assert {
  res.status: eq 200
}
