meta {
  name: 02 Create Household
  type: http
  seq: 4
}

post {
  url: {{BASE_URL}}/households
  body: json
  auth: bearer
}

auth:bearer {
  token: {{JWT_1}}
}

body:json {
  {
    "name": "Test Family",
    "timezone": "America/New_York"
  }
}

script:post-response {
  bru.setVar("HOUSEHOLD_ID", res.body.household.id);
  bru.setVar("INVITE_CODE", res.body.invite_code);
}

assert {
  res.status: eq 200
  res.body.household.id: isDefined
  res.body.invite_code: isDefined
}
