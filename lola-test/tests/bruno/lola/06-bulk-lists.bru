meta {
  name: 06 Bulk Create Lists
  type: http
  seq: 10
}

post {
  url: {{BASE_URL}}/lists/bulk
  body: json
  auth: bearer
}

auth:bearer {
  token: {{JWT_1}}
}

body:json {
  {
    "lists": [
      { "name": "Kitchen", "color": "#7CB99A", "emoji": "🍳" },
      { "name": "Laundry", "color": "#9AB7C9", "emoji": "👕" }
    ]
  }
}

script:post-response {
  const lists = res.body.lists;
  if (lists && lists.length > 0) {
    bru.setVar("LIST_ID", lists[0].id);
  }
}

assert {
  res.status: eq 200
}
