meta {
  name: 03c Session User 2
  type: http
  seq: 7
}

post {
  url: {{BASE_URL}}/auth/session
  body: json
  auth: bearer
}

auth:bearer {
  token: {{JWT_2}}
}

body:json {
  {
    "display_name": "Test User Two",
    "timezone": "America/New_York"
  }
}

script:post-response {
  bru.setVar("USER_ID_2", res.body.user.id);
}

assert {
  res.status: eq 200
}
