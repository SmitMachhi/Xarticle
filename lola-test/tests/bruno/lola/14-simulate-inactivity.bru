meta {
  name: 14 Simulate Inactivity (set catchup_pending)
  type: http
  seq: 18
}

docs {
  Directly sets catchup_pending=true on the household via Supabase REST API with service key.
  Replaces the non-existent simulate_inactivity RPC function.
}

patch {
  url: {{SUPABASE_URL}}/rest/v1/households?id=eq.{{HOUSEHOLD_ID}}
  body: json
  auth: none
}

headers {
  apikey: {{SUPABASE_SERVICE_KEY}}
  Authorization: Bearer {{SUPABASE_SERVICE_KEY}}
  Prefer: return=minimal
}

body:json {
  {
    "catchup_pending": true
  }
}

assert {
  res.status: in [200, 204]
}
