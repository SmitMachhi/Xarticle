meta {
  name: 03 Create Test User 2 (Admin)
  type: http
  seq: 5
}

docs {
  Creates test user 2 via Supabase admin API with email_confirm: true.
  Passes whether user is new (200) or already exists (422).
}

post {
  url: {{SUPABASE_URL}}/auth/v1/admin/users
  body: json
  auth: none
}

headers {
  apikey: {{SUPABASE_SERVICE_KEY}}
  Authorization: Bearer {{SUPABASE_SERVICE_KEY}}
  Content-Type: application/json
}

body:json {
  {
    "email": "{{TEST_EMAIL_2}}",
    "password": "{{TEST_PASSWORD}}",
    "email_confirm": true
  }
}

assert {
  res.status: in [200, 422]
}
