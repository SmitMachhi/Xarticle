meta {
  name: 20 Refresh Token
  type: http
  seq: 24
}

post {
  url: {{BASE_URL}}/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "{{REFRESH_TOKEN_1}}"
  }
}

script:post-response {
  bru.setVar("JWT_1", res.body.access_token);
}

assert {
  res.status: eq 200
  res.body.access_token: isDefined
  res.body.refresh_token: isDefined
}
