meta {
  name: 14b Seed Lola Catchup Message (direct insert)
  type: http
  seq: 19
}

docs {
  Inserts a lola_messages row directly with catchup_triage and catchup_clear actions.
  This seeds the message_id needed by test 16 (Lola Action - Catchup Triage).
  Using direct Supabase insert is more reliable than depending on the AI model
  to generate catchup action buttons.
}

post {
  url: {{SUPABASE_URL}}/rest/v1/lola_messages
  body: json
  auth: none
}

headers {
  apikey: {{SUPABASE_SERVICE_KEY}}
  Authorization: Bearer {{SUPABASE_SERVICE_KEY}}
  Prefer: return=representation
}

body:json {
  {
    "household_id": "{{HOUSEHOLD_ID}}",
    "user_id": "{{USER_ID_1}}",
    "role": "lola",
    "content": "Looks like things have been quiet around here. Want me to help sort out the backlog?",
    "actions": [
      {"action": "catchup_triage", "label": "Sort it out", "requires_role": "admin"},
      {"action": "catchup_clear", "label": "Fresh start", "requires_role": "admin"}
    ]
  }
}

script:post-response {
  const rows = res.body;
  if (Array.isArray(rows) && rows.length > 0) {
    bru.setVar("LOLA_MESSAGE_ID", rows[0].id);
  }
}

assert {
  res.status: in [200, 201]
}
